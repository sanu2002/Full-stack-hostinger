# ============================================================
#  Deployment configuration (read by docker-compose)
# ============================================================
# Copy this file to ".env" and fill in your server's public
# IP or domain. No trailing slash.
#
#   cp .env.example .env
#
# Change these TWO values to move the app to a new server or a
# real domain. Nothing else in the code needs to be touched.

# Public URL of the backend API (used by the frontend to call it).
SERVER_URL=http://YOUR_SERVER_IP:4000

# Frontend origin(s) allowed by the backend CORS policy.
# Comma-separate to allow several, e.g.
#   CLIENT_URL=http://YOUR_SERVER_IP:3000,https://yourdomain.com
CLIENT_URL=http://YOUR_SERVER_IP:3000
